#include <stdio.h>
#include <stdlib.h>

struct Node {
    int data;
    struct Node* next;
};

struct Node* insertLast(struct Node* head, int value) {
    
    // create new node
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = value;
    newNode->next = NULL;

    // if list is empty
    if (head == NULL) {
        return newNode;
    }

    // local variable for traversal
    struct Node* temp = head;

    // move to last node
    while (temp->next != NULL) {
        temp = temp->next;
    }

    // attach new node
    temp->next = newNode;

    return head;
}

// function to display list
void display(struct Node* head) {
    struct Node* temp = head;
    while (temp != NULL) {
        printf("%d -> ", temp->data);
        temp = temp->next;
    }
    printf("NULL\n");
}

int main() {
    struct Node* head = NULL;

    head = insertLast(head, 10);
    head = insertLast(head, 20);
    head = insertLast(head, 30);

    display(head);

    return 0;
}
